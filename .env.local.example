# Copy to .env.local and fill from Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Optional external UPC lookup (used by Scan In product lookup).
# Defaults to the UPCitemdb trial endpoint (no key) if unset.
# UPC_PROVIDER_URL=https://api.upcitemdb.com/prod/trial/lookup?upc=
# UPC_PROVIDER_NAME=upcitemdb
# UPC_API_KEY=

# Optional canonical site URL for password-reset links (defaults to the
# request origin, which already works on localhost and in production).
# NEXT_PUBLIC_SITE_URL=https://www.forgekeep.app
